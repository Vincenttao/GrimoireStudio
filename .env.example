# =========================================================
# Genesis Engine — LLM 配置示例
# 复制为 .env 并填入你自己的 key
# =========================================================

# 推荐默认：DashScope qwen-turbo（快+便宜，单章 ~¥0.3-0.5）
LLM_MODEL=openai/qwen-turbo
OPENAI_API_KEY=sk-your-dashscope-key
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 其他可选：
#   qwen-plus         — 质感更好，单章 ~¥1-1.5
#   qwen3.5-plus      — 顶配，单章 ~¥3-5，慢（3 分钟+/次）
#   deepseek-chat     — DeepSeek，便宜，中文还行（需换 DEEPSEEK_API_KEY）
#   gpt-4o-mini       — OpenAI 便宜线（需换 OPENAI_API_KEY 为真实 OpenAI key）
#   claude-3-5-haiku-latest — Claude 快线

# 其他供应商 API Key（只填你用的那个）：
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# Maestro 兜底（推演最多跑几轮）
MAX_TURNS=10
