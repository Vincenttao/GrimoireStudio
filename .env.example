# LLM Configuration
# Copy this file to .env and fill in your values

# Model to use (e.g., gpt-4, gpt-3.5-turbo, claude-3-sonnet, deepseek-chat)
LLM_MODEL=gpt-4

# API Keys (at least one required)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Custom API endpoint (optional)
# For Alibaba Cloud DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# For other OpenAI-compatible APIs
LLM_API_BASE=

# Maestro Tuning (optional)
MAX_TURNS=12
TENSION_THRESHOLD=0.8